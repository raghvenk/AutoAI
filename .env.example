# Ollama runs locally by default.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_VISION_MODEL=qwen2.5vl:7b
OLLAMA_TIMEOUT_SECONDS=900
OLLAMA_TEMPERATURE=0.1
OLLAMA_CONTEXT_WINDOW=16384
OLLAMA_MAX_OUTPUT_TOKENS=12288

# Required only when generating from a private Figma URL.
FIGMA_ACCESS_TOKEN=

# Limit source material sent in a single generation request.
QA_AGENT_MAX_SOURCE_CHARS=80000
QA_AGENT_MAX_UPLOAD_MB=25
